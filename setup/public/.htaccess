# SEF URL — Apache mod_rewrite (public/ kökü)
# XAMPP: ilgili dizinde AllowOverride All gerekir.
# Nginx: location bloğu changelog maddesinde özetlenmiştir.

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Mevcut dosya veya dizin — doğrudan servis et (assets, uploads, install.php, …)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Controller/Action — QSA ile ek sorgu parametrelerini koru (?status=active vb.)
    RewriteRule ^([A-Za-z][A-Za-z0-9_-]*)/([A-Za-z][A-Za-z0-9_-]*)/?$ index.php?controller=$1&action=$2 [QSA,L]
    RewriteRule ^([A-Za-z][A-Za-z0-9_-]*)/?$ index.php?controller=$1&action=index [QSA,L]
</IfModule>
