                    WHERE m.hasta_id = h.id
                    ORDER BY m.degerlendirme_tarihi DESC, m.id DESC LIMIT 1
                ), 99) < :mna_thr
                OR COALESCE((
                    SELECT bt.toplam_skor FROM esh_hasta_barthel AS bt
                    WHERE bt.hasta_id = h.id
                    ORDER BY bt.degerlendirme_tarihi DESC, bt.id DESC LIMIT 1
                ), 100) <= :barthel_dep_thr
            )
            AND (
                (
                    SELECT MAX(iz.izlemtarihi) FROM esh_izlemler AS iz
                    WHERE iz.hastatckimlik = h.tckimlik AND iz.yapildimi = 1
                ) IS NULL
                OR (
                    SELECT MAX(iz.izlemtarihi) FROM esh_izlemler AS iz
                    WHERE iz.hastatckimlik = h.tckimlik AND iz.yapildimi = 1
                ) < DATE_SUB(CURDATE(), INTERVAL :overdue_days DAY)
            )
