            COALESCE(iz.yizlemsayisi, 0) AS yizlemsayisi,
            COALESCE(pl.totalplanli, 0) AS totalplanli

            FROM esh_hastalar h

            LEFT JOIN esh_adrestablosu a1 ON h.ilce = a1.id

            LEFT JOIN esh_adrestablosu a2 ON h.mahalle = a2.id

            LEFT JOIN esh_adrestablosu a3 ON h.sokak = a3.id

            LEFT JOIN esh_adrestablosu a4 ON h.kapino = a4.id

             LEFT JOIN (

                SELECT hastatckimlik,

                    MAX(CASE WHEN yapildimi = 1 THEN izlemtarihi END) AS sonizlemtarihi,

                    SUM(yapildimi = 1) AS izlemsayisi,

                    SUM(yapildimi = 0) AS yizlemsayisi

                FROM esh_izlemler

                WHERE hastatckimlik IN (SELECT tckimlik FROM esh_hastalar WHERE id IN (5,31,32,33,34,35,61,62,63,64,65,91,92,93,94,95,121,122,123,124))

                GROUP BY hastatckimlik

            ) iz ON iz.hastatckimlik = h.tckimlik

            LEFT JOIN (

                SELECT hastatckimlik, COUNT(*) AS totalplanli

                FROM esh_pizlemler

                WHERE hastatckimlik IN (SELECT tckimlik FROM esh_hastalar WHERE id IN (5,31,32,33,34,35,61,62,63,64,65,91,92,93,94,95,121,122,123,124)) AND durum = 0

                GROUP BY hastatckimlik

            ) pl ON pl.hastatckimlik = h.tckimlik

            WHERE h.id IN (5,31,32,33,34,35,61,62,63,64,65,91,92,93,94,95,121,122,123,124)

            ORDER BY FIELD(h.id, 5,31,32,33,34,35,61,62,63,64,65,91,92,93,94,95,121,122,123,124)
